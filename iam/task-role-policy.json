{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ConfigBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::mapserver-docker-cloudnative-*",
        "arn:aws:s3:::mapserver-docker-cloudnative-*/*"
      ]
    },
    {
      "Sid": "S3ImageryPublicBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectTagging",
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "*"
    }
  ]
}
